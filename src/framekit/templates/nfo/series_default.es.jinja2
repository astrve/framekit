{% import "_macros.jinja2" as ui %}

{% if logo_text %}
{{ logo_text }}

{% endif %}

{{ ui.section("GENERAL") }}

{{ ui.line("Serie", release.series_title) }}
{{ ui.line("Año", release.year) }}
{{ ui.line("Grupo", release.team) }}
{{ ui.line("Fuente", release.source) }}
{{ ui.line("Resolución", release.resolution) }}
{{ ui.line("Vídeo", release.video_tag) }}
{{ ui.line("Audio", release.audio_tag) }}
{{ ui.line("Idioma", release.language_tag) }}
{{ ui.line("Idiomas de audio", release.audio_languages_display) }}
{{ ui.line("HDR", release.hdr_display) }}
{{ ui.line("Nombre completo", release.release_title) }}
{{ ui.line("Tamaño total", release.total_size_bytes | filesize) }}
{{ ui.line("Duración total", release.total_duration_ms | duration_ms) }}
{{ ui.line("Completitud de episodios", episode_completeness) }}
{% if metadata_season %}
{{ ui.section("METADATOS") }}
{{ ui.line("Temporada", metadata_season.season_number) }}
{{ ui.line("IMDb ID", metadata_season.imdb_id) }}
{{ ui.line("IMDb URL", metadata_season.external_url) }}

{% if metadata_season.overview %}
{{ ui.section("SINOPSIS DE LA SERIE") }}


{{ metadata_season.overview }}
{% endif %}
{% endif %}
{% if release.subtitle_summary_lines %}
{{ ui.section("SUBTÍTULOS") }}


{{ "- " ~ (release.subtitle_summary_lines | join("\n- ")) }}

{% endif %}
{{ ui.section("EPISODIOS") }}
{% for episode in episodes %}
{{ ui.sub_section(episode.episode_code or episode.file_name) }}
{{ ui.line("Archivo", episode.file_name) }}
{{ ui.line("Temporada/Episodio", episode.episode_code) }}
{{ ui.line("Título", episode.episode_title) }}
{{ ui.line("Tamaño", episode.size_bytes | filesize) }}
{{ ui.line("Duración", episode.duration_ms | duration_ms) }}
{{ ui.line("Tasa de bits global", episode.overall_bitrate_kbps | bitrate_kbps) }}
{{ ui.line("Resolución", episode.resolution) }}
{{ ui.line("Relación de aspecto", episode.aspect_ratio_display) }}
{{ ui.line("Vídeo", episode.video_codec) }}
{{ ui.line("HDR", episode.hdr_display) }}
{{ ui.line("Audio", episode.audio_summary | join(" | ")) }}
{{ ui.line("Subtítulos", episode.subtitle_summary | join(" | ")) }}

{% endfor %}