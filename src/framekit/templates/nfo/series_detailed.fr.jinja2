{% import "_macros.jinja2" as ui %}

{% if logo_text %}
{{ logo_text }}

{% endif %}

{{ ui.section("GÉNÉRAL") }}

{{ ui.line("Série", release.series_title) }}
{{ ui.line("Année", release.year) }}
{{ ui.line("Groupe", release.team) }}
{{ ui.line("Source", release.source) }}
{{ ui.line("Résolution", release.resolution) }}
{{ ui.line("Vidéo", release.video_tag) }}
{{ ui.line("Audio", release.audio_tag) }}
{{ ui.line("Langue", release.language_tag) }}
{{ ui.line("Langues audio", release.audio_languages_display) }}
{{ ui.line("HDR", release.hdr_display) }}
{{ ui.line("Nom complet", release.release_title) }}
{{ ui.line("Taille totale", release.total_size_bytes | filesize) }}
{{ ui.line("Durée totale", release.total_duration_ms | duration_ms) }}
{{ ui.line("Complétude épisodes", episode_completeness) }}


{% if metadata_season %}
{{ ui.section("MÉTADONNÉES") }}


{{ ui.line("Saison", metadata_season.season_number) }}
{{ ui.line("IMDb ID", metadata_season.imdb_id) }}
{{ ui.line("IMDb URL", metadata_season.external_url) }}

{% if metadata_season.overview %}
{{ ui.section("SYNOPSIS DE LA SÉRIE") }}


{{ metadata_season.overview }}
{% endif %}
{% endif %}
{% if release.subtitle_summary_by_episode %}
{{ ui.section("SOUS-TITRES PAR ÉPISODE") }}


{{ release.subtitle_summary_by_episode | join("\n\n") }}
{% endif %}

{{ ui.section("ÉPISODES") }}
{% for episode in episodes %}
{% set meta_episode = metadata_episode_map.get(episode.episode_code) if metadata_episode_map else none %}
{{ ui.section(episode.episode_code or episode.file_name) }}
{{ ui.line("Titre", meta_episode.episode_title if meta_episode and meta_episode.episode_title else episode.episode_title) }}
{{ ui.line("Date de diffusion", meta_episode.air_date if meta_episode else none) }}

{% if meta_episode and meta_episode.overview %}
{{ ui.line("Synopsis de l’épisode", meta_episode.overview) }}

{% endif %}

{{ ui.line("Fichier", episode.file_name) }}
{{ ui.line("Saison/Épisode", episode.episode_code) }}
{{ ui.line("Taille", episode.size_bytes | filesize) }}
{{ ui.line("Durée", episode.duration_ms | duration_ms) }}
{{ ui.line("Débit global", episode.overall_bitrate_kbps | bitrate_kbps) }}
{{ ui.line("Résolution", episode.resolution) }}
{{ ui.line("Ratio d’image", episode.aspect_ratio_display) }}
{{ ui.line("Vidéo", episode.video_codec) }}
{{ ui.line("HDR", episode.hdr_display) }}
{{ ui.line("Paramètres d'encodage", episode.video_encoding_settings) }}

{% for track in episode.video_tracks %}
{{ ui.track_section("PISTE VIDÉO", track.display_id) }}
{{ ui.format_and_codec(track.format_name, track.codec, "Format") }}
{{ ui.stream_size(track.size_bytes, track.size_percent, label="Taille du flux") }}
{{ ui.line("Débit", track.bitrate | bitrate) }}
{{ ui.line("Profondeur", track.bit_depth | bitdepth) }}
{{ ui.line("FPS", track.frame_rate | fps) }}

{% endfor %}
{% for track in episode.audio_tracks %}
{{ ui.track_section("PISTE AUDIO", track.display_id) }}
{{ ui.line("Langue", track.language_display) }}
{{ ui.line("Tag langue", track.language_short.upper() if track.language_short else none) }}
{{ ui.format_and_codec(track.format_name, track.codec, "Format") }}
{{ ui.line("Canaux", track.channels) }}
{{ ui.stream_size(track.size_bytes, track.size_percent, label="Taille du flux") }}
{{ ui.line("Débit", track.bitrate | bitrate) }}
{{ ui.line("Titre", track.title) }}
{{ ui.line("Par défaut", ui.yesno(track.is_default, "Oui", "Non")) }}

{% endfor %}
{% for track in episode.subtitle_tracks %}
{{ ui.track_section("PISTE DE SOUS-TITRES", track.display_id) }}
{{ ui.line("Langue", track.language_display) }}
{{ ui.line("Tag langue", track.language_short.upper() if track.language_short else none) }}
{{ ui.line("Variante", track.subtitle_variant) }}
{{ ui.format_and_codec(track.format_name, track.codec, "Format") }}
{{ ui.stream_size(track.size_bytes, track.size_percent, label="Taille du flux") }}
{{ ui.line("Débit", track.bitrate | bitrate) }}
{{ ui.line("Titre", track.title) }}
{{ ui.line("Par défaut", ui.yesno(track.is_default, "Oui", "Non")) }}
{{ ui.line("Forcé", ui.yesno(track.is_forced, "Oui", "Non")) }}

{% endfor %}
{% endfor %}